generator client {
  provider = "prisma-client-js"
  output   = "../../../node_modules/@prisma/auth-client"
}

datasource db {
  provider = "postgresql"
}

model User {
  id        String   @id @default(uuid())
  email     String   @unique
  name      String?
  password  String
  role      RoleType @default(USER)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

enum RoleType {
  USER
  ADMIN
}